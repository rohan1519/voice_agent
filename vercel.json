{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    {
      "src": "backend/api/**/*.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/api/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
